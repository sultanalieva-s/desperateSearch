# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── HH.ru (search works without auth; apply requires OAuth) ───────────────────
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_ACCESS_TOKEN=

# ── LinkedIn (stored session cookies for Playwright) ──────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Glassdoor ─────────────────────────────────────────────────────────────────
GLASSDOOR_EMAIL=
GLASSDOOR_PASSWORD=

# ── Djinni ────────────────────────────────────────────────────────────────────
DJINNI_EMAIL=
DJINNI_PASSWORD=

# ── Telegram channels to scan (comma-separated @usernames or -100xxxxx IDs) ──
TG_JOB_CHANNELS=@python_jobs,@it_vacancies_worldwide

# ── Scan interval in seconds (default: 1800 = 30 minutes) ────────────────────
SCAN_INTERVAL=1800
